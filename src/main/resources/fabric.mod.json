{
	"schemaVersion": 1,
	"id": "itemmagnetmod",
	"version": "${version}",
	"name": "Item Magnet Mod",
	"description": "This mod adds an item magnet to the game. It can be activated / deactivated and looses durability for each item picked up.",
	"authors": [
		"davdeo"
	],
	"contributors": [
		"StarmanMine142"
	],
	"contact": {
		"homepage":"https://modrinth.com/mod/davdeos-item-magnet",
		"sources": "https://github.com/davdeo/mc-item-magnet-mod",
		"issues": "https://github.com/davdeo/mc-item-magnet-mod/issues"
	},
	"license": "MIT",
	"icon": "assets/itemmagnetmod/mod_icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.davdeo.itemmagnetmod.ItemMagnetMod"
		],
		"client": [
			"net.davdeo.itemmagnetmod.ItemMagnetModClient"
		],
		"fabric-datagen": [
			"net.davdeo.itemmagnetmod.ItemMagnetModDataGenerator"
		],
		"modmenu": [
			"net.davdeo.itemmagnetmod.config.ModMenuIntegration"
		]
	},
	"mixins": [
		"itemmagnetmod.mixins.json"
	],
	"depends": {
		"fabricloader": ">=${loader_version}",
		"minecraft": "~${min_minecraft_version}",
		"java": ">=${java_version}",
		"fabric-api": "*"
	},
	"suggests": {
		"cloth-config": "*",
		"modmenu": "*"
	},
	"accessWidener": "itemmagnetmod.accesswidener"
}
